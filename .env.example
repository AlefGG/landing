# Base URL for Django API. Dev default points at local backend container.
# Prod builds serve the SPA from the same origin as the API — use "/api".
# E2E runs: Playwright's webServer overrides this to http://localhost:8001/api
# so the SPA talks to the backend_e2e container (see tests/e2e/README.md).
VITE_API_URL=http://localhost:8000/api

# Slug of the landing-tenant company. MUST match backend LANDING_COMPANY_SLUG.
# Empty value disables the public zones overlay (frontend will not call /api/public/zones/).
VITE_LANDING_COMPANY_SLUG=
