# Copy to .env.local for local dev overrides.

# Base URL for Django API. Empty = same-origin (SPA hits /api/...).
# Dev default points at local backend container (http://localhost:8000/api).
# Prod builds serve the SPA from the same origin as the API — leave empty or use "/api".
# E2E runs: Playwright's webServer overrides this to http://localhost:8001/api
# so the SPA talks to the backend_e2e container (see tests/e2e/README.md).
# Localhost values are blocked by vite.config.ts during `mode === 'production'` builds.
VITE_API_URL=http://localhost:8000/api

# Slug of the landing-tenant company. MUST match backend LANDING_COMPANY_SLUG.
# Empty value disables the public zones overlay (frontend will not call /api/public/zones/).
VITE_LANDING_COMPANY_SLUG=

# Sentry DSN for runtime error reporting. Empty = disabled gracefully.
# Set via CI secret in production. (Used by Task 4 / FE-BUILD-003.)
VITE_SENTRY_DSN=
